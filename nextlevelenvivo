  .app{max-width:700px;margin:0 auto;padding:14px;}

  /* HEADER */
  .header{background:linear-gradient(135deg,var(--verde),var(--verde2));border-radius:14px;padding:18px;text-align:center;margin-bottom:14px;position:relative;overflow:hidden;}
  .header::before{content:'';position:absolute;inset:-20px;background:repeating-linear-gradient(45deg,rgba(255,255,255,.03) 0,rgba(255,255,255,.03) 10px,transparent 10px,transparent 20px);}
  .header h1{font-family:'Barlow Condensed',sans-serif;font-size:26px;font-weight:700;letter-spacing:2px;position:relative;color:#fff;}
  .header p{font-size:12px;opacity:.8;margin-top:3px;position:relative;color:#fff;}
  .live-badge{display:inline-flex;align-items:center;gap:6px;background:var(--rojo);color:white;font-size:11px;font-weight:600;padding:3px 12px;border-radius:20px;margin-bottom:8px;position:relative;}
  .live-dot{width:7px;height:7px;background:white;border-radius:50%;animation:blink 1.2s infinite;}
  @keyframes blink{0%,100%{opacity:1}50%{opacity:.15}}

  /* TABS */
  .tabs{display:flex;gap:8px;margin-bottom:12px;}
  .tab{flex:1;border:1px solid var(--border);background:var(--bg2);color:var(--text2);border-radius:10px;padding:9px;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s;letter-spacing:.5px;}
  .tab.active{background:var(--verde);color:#fff;border-color:var(--verde);}
  .tab:hover:not(.active){background:var(--bg3);}

  /* SECTION */
  .section{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:14px;margin-bottom:12px;}
  .section h3{font-size:12px;color:var(--text2);text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;}

  /* PARTIDO ITEM */
  .partido-item{display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--bg3);border:1px solid var(--border);border-radius:10px;cursor:pointer;transition:all .2s;margin-bottom:7px;}
  .partido-item:hover{border-color:var(--verde2);background:#1e3024;}
  .partido-item img{width:28px;height:28px;object-fit:contain;}
  .partido-info{flex:1;}
  .partido-info strong{font-size:13px;color:var(--text);}
  .partido-info small{font-size:11px;color:var(--text2);display:block;margin-top:2px;}
  .badge{font-size:10px;font-weight:600;padding:3px 10px;border-radius:20px;background:#1e3a20;color:#5dba6a;}
  .badge.jugado{background:#1a2a3a;color:#5a9fd4;}
  .badge.live{background:var(--rojo);color:#fff;animation:blink 1.2s infinite;}
  .sec-label{font-size:11px;color:var(--text2);text-transform:uppercase;letter-spacing:1px;margin:10px 0 6px;font-weight:600;}

  /* SCOREBOARD */
  .scoreboard{display:grid;grid-template-columns:1fr 100px 1fr;gap:10px;align-items:center;margin-bottom:12px;}
  .team-card{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:12px 8px;text-align:center;}
  .team-logo{width:52px;height:52px;object-fit:contain;margin-bottom:7px;}
  .team-name{font-family:'Barlow Condensed',sans-serif;font-size:14px;font-weight:600;letter-spacing:.5px;color:var(--text);}
  .score-box{background:linear-gradient(180deg,var(--verde),#0f3018);border-radius:14px;padding:12px 6px;text-align:center;border:1px solid var(--verde);}
  .score-nums{display:flex;align-items:center;justify-content:center;gap:5px;}
  .score-num{font-family:'Barlow Condensed',sans-serif;font-size:44px;font-weight:700;color:#fff;line-height:1;}
  .score-sep{font-size:22px;color:rgba(255,255,255,.4);}
  .score-time{font-size:11px;color:rgba(255,255,255,.6);margin-top:4px;}

  /* MATCH BTNS */
  .match-btns{display:flex;gap:7px;margin-bottom:12px;flex-wrap:wrap;align-items:center;}
  .mbtn{border:1px solid var(--border);background:var(--bg2);color:var(--text2);border-radius:8px;padding:7px 14px;font-size:12px;font-weight:600;cursor:pointer;transition:all .2s;}
  .mbtn:hover{background:var(--bg3);}
  .mbtn.active{background:var(--verde);color:#fff;border-color:var(--verde);}
  .status-pill{font-size:11px;padding:4px 12px;border-radius:20px;background:var(--bg3);color:var(--text2);border:1px solid var(--border);}

  /* ACTIONS */
  .actions-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
  .act-col{display:flex;flex-direction:column;gap:8px;}
  .act-title{display:flex;align-items:center;gap:7px;font-size:13px;font-weight:600;color:var(--text);padding-bottom:6px;border-bottom:1px solid var(--border);}
  .act-title img{width:24px;height:24px;object-fit:contain;}
  .act-row{display:flex;align-items:center;justify-content:space-between;gap:6px;}
  .act-row span{font-size:12px;color:var(--text2);}
  .btn-pair{display:flex;gap:4px;}
  .btn{border:1px solid var(--border);background:var(--bg3);color:var(--text);border-radius:7px;padding:6px 12px;font-size:12px;font-weight:600;cursor:pointer;transition:all .15s;}
  .btn:hover{opacity:.85;}
  .btn:active{transform:scale(.97);}
  .btn-goal{background:#1e3a20;border-color:#4caf50;color:#7dd87d;}
  .btn-yellow{background:#2a2010;border-color:var(--yellow);color:var(--yellow);}
  .btn-red{background:#2a1010;border-color:var(--red);color:var(--red);}
  .btn-undo{background:var(--bg3);font-size:11px;color:var(--text2);}
  .psel{width:100%;background:var(--bg);border:1px solid var(--border);color:var(--text2);border-radius:7px;padding:6px 8px;font-size:12px;margin-top:3px;}
  .psel option{background:var(--bg);}
  .min-row{display:flex;align-items:center;gap:8px;margin-bottom:10px;}
  .min-row label{font-size:12px;color:var(--text2);}
  .min-input{width:80px;background:var(--bg);border:1px solid var(--border);color:var(--text);border-radius:7px;padding:6px 8px;font-size:13px;font-weight:600;}
  .yb{display:inline-block;width:11px;height:15px;background:var(--yellow);border-radius:2px;vertical-align:middle;margin-right:3px;}
  .rb{display:inline-block;width:11px;height:15px;background:var(--red);border-radius:2px;vertical-align:middle;margin-right:3px;}

  /* STATS */
  .stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:7px;margin-bottom:12px;}
  .stat-mini{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:10px;text-align:center;}
  .stat-num{font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:700;color:var(--text);}
  .stat-lbl{font-size:10px;color:var(--text2);margin-top:2px;}

  /* EVENTS */
  .events-list{max-height:200px;overflow-y:auto;display:flex;flex-direction:column;gap:6px;}
  .event-item{display:flex;align-items:center;gap:8px;padding:8px 11px;background:var(--bg3);border-radius:8px;font-size:12px;border-left:3px solid var(--border);}
  .event-item.goal{border-left-color:#4caf50;}
  .event-item.yellow{border-left-color:var(--yellow);}
  .event-item.red{border-left-color:var(--red);}
  .event-min{font-size:11px;color:var(--text2);min-width:28px;font-weight:600;}
  .event-icon{font-size:15px;}
  .event-text{color:var(--text);flex:1;}
  .event-team{font-size:11px;color:var(--text2);}
  .no-events{text-align:center;color:var(--text2);font-size:13px;padding:22px;}
  .hidden{display:none!important;}
  .partido-activo{background:var(--bg3);border:1px solid var(--verde);border-radius:10px;padding:10px 14px;text-align:center;font-size:13px;font-weight:600;color:var(--verde2);margin-bottom:12px;}
  .danger-btn{border:1px solid #5a2020;background:#2a1010;color:#ef9090;border-radius:8px;padding:7px 14px;font-size:12px;cursor:pointer;}
  .danger-btn:hover{background:#3a1515;}
</style>
</head>
