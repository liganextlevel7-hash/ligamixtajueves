  {id:5,local:1,visita:2,gLocal:1,gVisita:5,estado:"Jugado",jornada:"J3"},
  {id:6,local:3,visita:6,gLocal:2,gVisita:0,estado:"Jugado",jornada:"J2"},
  {id:7,local:5,visita:7,gLocal:1,gVisita:0,estado:"Jugado",jornada:"J2"},
  {id:12,local:5,visita:1,gLocal:3,gVisita:1,estado:"Jugado",jornada:"J5"},
  {id:13,local:2,visita:6,gLocal:2,gVisita:5,estado:"Jugado",jornada:"J4"},
  {id:14,local:8,visita:4,gLocal:0,gVisita:4,estado:"Jugado",jornada:"J5"}
];

var live = {scoreLocal:0,scoreVisita:0,yellowLocal:0,redLocal:0,yellowVisita:0,redVisita:0,events:[],minute:0,status:'sin',partidoId:null,localId:null,visitaId:null};

function showTab(t){
  document.getElementById('tab-partidos').classList.toggle('hidden',t!=='partidos');
  document.getElementById('tab-live').classList.toggle('hidden',t!=='live');
  document.querySelectorAll('.tab').forEach(function(b,i){b.classList.toggle('active',(i===0&&t==='partidos')||(i===1&&t==='live'));});
}

function renderPartidos(){
  var pend = partidos.filter(function(p){return p.estado==='Pendiente';});
  var jug = partidos.filter(function(p){return p.estado==='Jugado';});
  var html = '<p class="sec-label">📅 Próximos partidos — clic para transmitir</p>';
  pend.forEach(function(p){
    var eL=equipos[p.local]||{nombre:'Eq.'+p.local,logo:''};
    var eV=equipos[p.visita]||{nombre:'Eq.'+p.visita,logo:''};
    html+='<div class="partido-item" onclick="selectPartido('+p.id+')">'
      +'<img src="'+eL.logo+'" onerror="this.style.display=\'none\'">'
      +'<div class="partido-info"><strong>'+eL.nombre+' vs '+eV.nombre+'</strong><small>'+p.jornada+'</small></div>'
      +'<img src="'+eV.logo+'" onerror="this.style.display=\'none\'">'
      +'<span class="badge">Pendiente</span></div>';
  });
  html+='<p class="sec-label" style="margin-top:14px;">✅ Resultados</p>';
  jug.forEach(function(p){
    var eL=equipos[p.local]||{nombre:'Eq.'+p.local,logo:''};
    var eV=equipos[p.visita]||{nombre:'Eq.'+p.visita,logo:''};
    html+='<div class="partido-item" onclick="selectPartido('+p.id+')">'
      +'<img src="'+eL.logo+'" onerror="this.style.display=\'none\'">'
      +'<div class="partido-info"><strong>'+eL.nombre+' '+p.gLocal+' - '+p.gVisita+' '+eV.nombre+'</strong><small>'+p.jornada+'</small></div>'
      +'<img src="'+eV.logo+'" onerror="this.style.display=\'none\'">'
      +'<span class="badge jugado">Jugado</span></div>';
  });
  document.getElementById('lista-partidos').innerHTML=html;
}

function selectPartido(pid){
  var p=partidos.find(function(x){return x.id===pid;});
  if(!p) return;
  live.partidoId=pid; live.localId=p.local; live.visitaId=p.visita;
  live.scoreLocal=p.gLocal||0; live.scoreVisita=p.gVisita||0;
  live.yellowLocal=0;live.redLocal=0;live.yellowVisita=0;live.redVisita=0;
  live.events=[];live.minute=0;live.status='sin';
  var eL=equipos[p.local]||{nombre:'Eq.'+p.local,logo:''};
  var eV=equipos[p.visita]||{nombre:'Eq.'+p.visita,logo:''};
  document.getElementById('logo-local').src=eL.logo;
  document.getElementById('logo-visita').src=eV.logo;
  document.getElementById('name-local').textContent=eL.nombre;
  document.getElementById('name-visita').textContent=eV.nombre;
  document.getElementById('act-logo-local').src=eL.logo;
  document.getElementById('act-logo-visita').src=eV.logo;
  document.getElementById('act-name-local').textContent=eL.nombre;
  document.getElementById('act-name-visita').textContent=eV.nombre;
  document.getElementById('partido-activo-label').textContent='🎙️ Transmitiendo: '+eL.nombre+' vs '+eV.nombre;
  fillPlayerSelects(p.local,p.visita);
  ['btn-inicio','btn-medio','btn-fin'].forEach(function(id){document.getElementById(id).classList.remove('active');});
  document.getElementById('status-pill').textContent='Sin iniciar';
  renderLive();
  showTab('live');
}

function fillPlayerSelects(eidL,eidV){
  var jL=jugadores.filter(function(j){return j.equipo===eidL;});
  var jV=jugadores.filter(function(j){return j.equipo===eidV;});
  function opts(list){
    return '<option value="">— Jugador —</option>'+list.map(function(j){
      return '<option value="'+j.id+'">#'+j.numero+' '+(j.apodo||j.nombre)+'</option>';
    }).join('');
  }
  ['sel-gol-local','sel-yellow-local','sel-red-local'].forEach(function(id){document.getElementById(id).innerHTML=opts(jL);});
  ['sel-gol-visita','sel-yellow-visita','sel-red-visita'].forEach(function(id){document.getElementById(id).innerHTML=opts(jV);});
}

function getMinute(){var v=document.getElementById('inp-minuto').value;return v?parseInt(v):live.minute;}

function getPlayerName(side,type){
  var sel=document.getElementById('sel-'+type+'-'+side);
  if(!sel||!sel.value) return '';
  var j=jugadores.find(function(x){return x.id===parseInt(sel.value);});
  return j?(j.apodo||j.nombre):'';
}

function addEvent(type,side){
  var min=getMinute();
  var name=side==='local'?document.getElementById('name-local').textContent:document.getElementById('name-visita').textContent;
  var player=getPlayerName(side,type==='goal'?'gol':type);
  live.events.unshift({type:type,side:side,minute:min,teamName:name,player:player});
  if(type==='goal'){if(side==='local')live.scoreLocal++;else live.scoreVisita++;}
  if(type==='yellow'){if(side==='local')live.yellowLocal++;else live.yellowVisita++;}
  if(type==='red'){if(side==='local')live.redLocal++;else live.redVisita++;}
  live.minute=min;
  renderLive();
}

function removeGoal(side){
  if(side==='local'&&live.scoreLocal>0){live.scoreLocal--;live.events.unshift({type:'undo',side:side,minute:getMinute(),teamName:document.getElementById('name-local').textContent,player:''});}
  else if(side==='visita'&&live.scoreVisita>0){live.scoreVisita--;live.events.unshift({type:'undo',side:side,minute:getMinute(),teamName:document.getElementById('name-visita').textContent,player:''});}
  renderLive();
}

function setStatus(s){
  var labels={inicio:'En juego ▶',medio:'Medio tiempo ⏸',fin:'Finalizado 🏁',sin:'Sin iniciar'};
  live.status=s;
  document.getElementById('status-pill').textContent=labels[s];
  ['btn-inicio','btn-medio','btn-fin'].forEach(function(id){document.getElementById(id).classList.remove('active');});
  document.getElementById('btn-'+s).classList.add('active');
  if(s==='inicio'){live.minute=1;document.getElementById('match-time').textContent="1'";}
  if(s==='medio')document.getElementById('match-time').textContent="45'";
  if(s==='fin')document.getElementById('match-time').textContent="90'";
}

function renderLive(){
  document.getElementById('score-local').textContent=live.scoreLocal;
  document.getElementById('score-visita').textContent=live.scoreVisita;
  if(live.minute>0)document.getElementById('match-time').textContent=live.minute+"'";
  document.getElementById('st-yl').textContent=live.yellowLocal;
  document.getElementById('st-rl').textContent=live.redLocal;
  document.getElementById('st-yv').textContent=live.yellowVisita;
  document.getElementById('st-rv').textContent=live.redVisita;
  var list=document.getElementById('events-list');
  if(live.events.length===0){list.innerHTML='<div class="no-events">Los eventos aparecerán aquí durante el partido</div>';return;}
  var icons={goal:'⚽',yellow:'🟨',red:'🟥',undo:'↩️'};
  var labels={goal:'Gol',yellow:'Tarjeta amarilla',red:'Tarjeta roja',undo:'Gol anulado'};
  list.innerHTML=live.events.map(function(e){
    return '<div class="event-item '+e.type+'"><span class="event-min">'+e.minute+"'</span><span class=\"event-icon\">"+icons[e.type]+'</span><span class="event-text">'+labels[e.type]+(e.player?' — '+e.player:'')+'</span><span class="event-team">'+e.teamName+'</span></div>';
  }).join('');
}

function resetLive(){
  if(!confirm('¿Reiniciar el partido?'))return;
  live.scoreLocal=0;live.scoreVisita=0;live.yellowLocal=0;live.redLocal=0;live.yellowVisita=0;live.redVisita=0;live.events=[];live.minute=0;live.status='sin';
  ['btn-inicio','btn-medio','btn-fin'].forEach(function(id){document.getElementById(id).classList.remove('active');});
  document.getElementById('status-pill').textContent='Sin iniciar';
  renderLive();
}

renderPartidos();
</script>
</body>
</html>
